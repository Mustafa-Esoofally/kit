# Required
OPENAI_API_KEY=

# Required for Telegram interface
TELEGRAM_TOKEN=

# Telegram webhook secret — generate with: openssl rand -hex 32
# Must match the secret_token you pass to Telegram's setWebhook API.
# Required in production (any value other than APP_ENV=development).
# See README.md > Integrations > Telegram for the full setup flow.
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Database (defaults suit the compose.yaml pgvector service)
DB_DRIVER=postgresql+psycopg
DB_HOST=localhost
DB_PORT=5432
DB_USER=ai
DB_PASS=ai
DB_DATABASE=ai

# Override the default model
KIT_MODEL=gpt-4o-mini

# User-authored context directory
KIT_CONTEXT_DIR=./context

# Runtime environment (prd enables JWT auth)
RUNTIME_ENV=dev
# Set APP_ENV=development to bypass Telegram webhook secret validation locally
APP_ENV=development
