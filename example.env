# Required
OPENAI_API_KEY=

# Required for Telegram interface (primary)
TELEGRAM_TOKEN=

# Optional — Slack interface
SLACK_TOKEN=
SLACK_SIGNING_SECRET=

# Optional — override the default model
KIT_MODEL=gpt-4o-mini

# Optional — user-authored context directory
KIT_CONTEXT_DIR=./context

# Optional — SQLite file path (defaults to tmp/kit.db)
KIT_DB_FILE=
